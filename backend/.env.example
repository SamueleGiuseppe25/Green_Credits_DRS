# GreenCredits Backend — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# PostgreSQL async URL (required in production)
# Example: postgresql+asyncpg://gc:gc@localhost:5432/greencredits
DATABASE_URL=

# Set to true to use SQLite instead of Postgres (dev only, no DATABASE_URL needed)
USE_SQLITE_DEV=false

# ---------------------------------------------------------------------------
# Auth (JWT)
# ---------------------------------------------------------------------------

# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=dev-secret-replace-in-production

JWT_ALGORITHM=HS256

# Token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---------------------------------------------------------------------------
# Stripe (test mode)
# ---------------------------------------------------------------------------

# From Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# From Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------------
# Email (Resend)
# ---------------------------------------------------------------------------

# From https://resend.com/api-keys
RESEND_API_KEY=re_...

# ---------------------------------------------------------------------------
# CORS / Frontend
# ---------------------------------------------------------------------------

# The frontend origin — used for CORS and email link generation
# Example: https://green-credits-drs.vercel.app
FRONTEND_URL=http://localhost:5173

# Comma-separated list of allowed CORS origins
# Example: https://green-credits-drs.vercel.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------

# Set to "production" on Railway
ENVIRONMENT=development
